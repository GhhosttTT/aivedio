# ============================================
# AI 短剧自动化生产平台 - 环境变量配置示例
# ============================================

# -------------------- LLM 配置 --------------------
# Qwen2.5-14B GGUF 模型路径
LLM_MODEL_PATH=./models/qwen2.5-14b-instruct-q4_k_m.gguf
# GPU 加载的层数（剩余层 offload 到 CPU）
LLM_N_GPU_LAYERS=20
# 上下文窗口大小
LLM_N_CTX=4096
# CPU 线程数
LLM_N_THREADS=8

# -------------------- ComfyUI 配置 --------------------
# ComfyUI 服务地址
COMFYUI_BASE_URL=http://127.0.0.1:8188
# ComfyUI 工作流配置文件路径
COMFYUI_WORKFLOW_PATH=./configs/comfyui_workflow.json
# Stable Diffusion XL 模型路径
SDXL_MODEL_PATH=./models/stable-diffusion-xl-base-1.0/sd_xl_base_1.0.safetensors

# -------------------- SVD 配置 --------------------
# Stable Video Diffusion 模型路径
SVD_MODEL_PATH=./models/stable-video-diffusion-img2vid-xt
# 视频帧数
SVD_NUM_FRAMES=16
# 视频帧率
SVD_FPS=8

# -------------------- TTS 配置 --------------------
# MiMo-V2-TTS API 密钥
TTS_API_KEY=your_mimo_api_key_here
# TTS API 基础 URL
TTS_BASE_URL=https://mimo.xiaomi.com/api/v2/tts

# -------------------- 数据库配置 --------------------
# 数据库连接 URL（SQLite）
DATABASE_URL=sqlite:///./short_drama.db
# 或使用 PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/short_drama

# -------------------- Redis 配置 --------------------
# Redis 连接 URL
REDIS_URL=redis://localhost:6379/0

# -------------------- Celery 配置 --------------------
# Celery Broker URL
CELERY_BROKER_URL=redis://localhost:6379/1
# Celery Result Backend URL
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Celery Worker 并发数
CELERY_WORKER_CONCURRENCY=2

# -------------------- 文件存储配置 --------------------
# 文件存储根目录
STORAGE_PATH=./storage
# 最大存储空间（GB）
MAX_STORAGE_SIZE_GB=500

# -------------------- 安全配置 --------------------
# 加密密钥（用于加密 API 密钥等敏感信息）
ENCRYPTION_KEY=your_encryption_key_here
# JWT 密钥（请在生产环境中更改为随机字符串）
JWT_SECRET_KEY=your_jwt_secret_key_here
# JWT 算法
JWT_ALGORITHM=HS256
# JWT 访问令牌过期时间（小时）
JWT_EXPIRATION_HOURS=24
# JWT 刷新令牌过期时间（天）
JWT_REFRESH_EXPIRATION_DAYS=7

# -------------------- 性能配置 --------------------
# GPU 显存使用比例
GPU_MEMORY_FRACTION=0.95
# 是否启用 GPU 缓存清理
ENABLE_GPU_CACHE_CLEAR=true
# API 速率限制
API_RATE_LIMIT=10/minute

# -------------------- 日志配置 --------------------
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# -------------------- API 配置 --------------------
# API 服务地址
API_HOST=0.0.0.0
# API 服务端口
API_PORT=8000
# 是否启用热重载（开发环境）
API_RELOAD=false
# CORS 允许的源（逗号分隔，* 表示允许所有）
CORS_ORIGINS=*

# -------------------- 开发配置 --------------------
# 是否启用调试模式
DEBUG=false
# 是否启用热重载
RELOAD=false

# -------------------- Source Video Localization --------------------
LOCALIZATION_TARGET_LANGUAGES=en,es,pt,ar,id,th,vi,ja,ko
SUBTITLE_REMOVAL_BACKEND=manual_mask
OCCLUSION_REMOVAL_BACKEND=auto_video_inpaint
OCCLUSION_MASK_DETECTOR_COMMAND=
OCCLUSION_AUTO_MASK_MIN_CONFIDENCE=0.65
OCCLUSION_MIN_QUALITY_SCORE=0.92
OCCLUSION_REMOVAL_TIMEOUT_SECONDS=7200
AUTO_VIDEO_INPAINT_COMMAND=
PROPINTER_COMMAND=
VSR_COMMAND=
ASR_BACKEND=faster_whisper
ASR_MODEL_PATH=./models/faster-whisper-large-v3
TRANSLATION_BACKEND=local_llm
MODERATION_BACKEND=rules
LOCALIZATION_CONCURRENCY=1

# -------------------- Generation Quality --------------------
GENERATION_PROVIDER=local_comfyui
GENERATION_PRIMARY_PROVIDER=jimeng_api
GENERATION_QUALITY_PROFILE=hongguo_reference
COMFYUI_DEFAULT_WORKFLOW_TYPE=juggernaut
JIMENG_ENDPOINT=
JIMENG_API_KEY=
KLING_ENDPOINT=
KLING_API_KEY=
HAILUO_ENDPOINT=
HAILUO_API_KEY=
