# ============================================
# AI 短剧自动化生产平台 - 环境变量配置示例
# ============================================

# -------------------- LLM 配置 --------------------
# Qwen2.5-14B GGUF 模型路径
LLM_MODEL_PATH=./models/qwen2.5-14b-instruct-q4_k_m.gguf
# GPU 加载的层数（剩余层 offload 到 CPU）
LLM_N_GPU_LAYERS=20
# 上下文窗口大小
LLM_N_CTX=4096
# CPU 线程数
LLM_N_THREADS=8

# -------------------- ComfyUI 配置 --------------------
# ComfyUI 服务地址
COMFYUI_BASE_URL=http://127.0.0.1:8188
# ComfyUI 工作流配置文件路径
COMFYUI_WORKFLOW_PATH=./configs/comfyui_workflow.json

# -------------------- SVD 配置 --------------------
# Stable Video Diffusion 模型路径
SVD_MODEL_PATH=./models/stable-video-diffusion-img2vid-xt
# 视频帧数
SVD_NUM_FRAMES=16
# 视频帧率
SVD_FPS=8

# -------------------- TTS 配置 --------------------
# MiMo-V2-TTS API 密钥
TTS_API_KEY=your_mimo_api_key_here
# TTS API 基础 URL
TTS_BASE_URL=https://mimo.xiaomi.com/api/v2/tts

# -------------------- 数据库配置 --------------------
# 数据库连接 URL（SQLite）
DATABASE_URL=sqlite:///./short_drama.db
# 或使用 PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/short_drama

# -------------------- Redis 配置 --------------------
# Redis 连接 URL
REDIS_URL=redis://localhost:6379/0

# -------------------- Celery 配置 --------------------
# Celery Broker URL
CELERY_BROKER_URL=redis://localhost:6379/1
# Celery Result Backend URL
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Celery Worker 并发数
CELERY_WORKER_CONCURRENCY=2

# -------------------- 文件存储配置 --------------------
# 文件存储根目录
STORAGE_PATH=./storage
# 最大存储空间（GB）
MAX_STORAGE_SIZE_GB=500

# -------------------- 安全配置 --------------------
# 加密密钥（用于加密 API 密钥等敏感信息）
ENCRYPTION_KEY=your_encryption_key_here
# JWT 密钥
JWT_SECRET_KEY=your_jwt_secret_key_here
# JWT 过期时间（小时）
JWT_EXPIRATION_HOURS=24

# -------------------- 性能配置 --------------------
# GPU 显存使用比例
GPU_MEMORY_FRACTION=0.95
# 是否启用 GPU 缓存清理
ENABLE_GPU_CACHE_CLEAR=true
# API 速率限制
API_RATE_LIMIT=10/minute

# -------------------- 日志配置 --------------------
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# -------------------- 开发配置 --------------------
# 是否启用调试模式
DEBUG=false
# 是否启用热重载
RELOAD=false
