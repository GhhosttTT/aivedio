{
  "workflow": {
    "name": "AI Short Drama Fast Image Generation",
    "description": "快速文生图工作流 - 优化速度和角色一致性",
    "version": "1.0.0"
  },
  "nodes": {
    "checkpoint_loader": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "v1-5-pruned-emaonly.safetensors"
      }
    },
    "ipadapter_loader": {
      "class_type": "IPAdapterUnifiedLoaderFaceID",
      "inputs": {
        "model": ["checkpoint_loader", 0],
        "preset": "FACEID PLUS V2",
        "lora_strength": 0.6,
        "provider": "CPU"
      }
    },
    "clip_vision_loader": {
      "class_type": "CLIPVisionLoader",
      "inputs": {
        "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
      }
    },
    "load_reference_image": {
      "class_type": "LoadImage",
      "inputs": {
        "image": ""
      }
    },
    "apply_ipadapter": {
      "class_type": "IPAdapterFaceID",
      "inputs": {
        "model": ["ipadapter_loader", 0],
        "ipadapter": ["ipadapter_loader", 1],
        "image": ["load_reference_image", 0],
        "weight": 0.8,
        "weight_faceidv2": 1.0,
        "weight_type": "linear",
        "combine_embeds": "concat",
        "start_at": 0.0,
        "end_at": 1.0,
        "embeds_scaling": "V only"
      }
    },
    "clip_text_encode_positive": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "(masterpiece, best quality, ultra-detailed:1.2), (handsome man:1.3), beautiful face, perfect anatomy, sharp focus, professional photography, cinematic lighting, 8k uhd, highly detailed",
        "clip": ["checkpoint_loader", 1]
      }
    },
    "clip_text_encode_negative": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "(worst quality, low quality:1.4), (ugly:1.3), deformed, distorted, disfigured, bad anatomy, bad hands, missing limbs, extra limbs, fused fingers, too many fingers, long neck, mutation, mutated, blurry, jpeg artifacts, text, watermark, signature, cartoon, anime, 3d render, plastic skin, doll-like",
        "clip": ["checkpoint_loader", 1]
      }
    },
    "empty_latent_image": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": 768,
        "height": 512,
        "batch_size": 1
      }
    },
    "ksampler": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 0,
        "steps": 15,
        "cfg": 7.0,
        "sampler_name": "euler_ancestral",
        "scheduler": "normal",
        "denoise": 1.0,
        "model": ["apply_ipadapter", 0],
        "positive": ["clip_text_encode_positive", 0],
        "negative": ["clip_text_encode_negative", 0],
        "latent_image": ["empty_latent_image", 0]
      }
    },
    "vae_decode": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["ksampler", 0],
        "vae": ["checkpoint_loader", 2]
      }
    },
    "save_image": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "short_drama_fast",
        "images": ["vae_decode", 0]
      }
    }
  },
  "parameters": {
    "default": {
      "width": 768,
      "height": 512,
      "steps": 15,
      "cfg_scale": 7.0,
      "sampler": "euler_ancestral",
      "scheduler": "normal",
      "seed": -1,
      "ipadapter_weight": 0.8,
      "ipadapter_lora_strength": 0.6
    },
    "presets": {
      "ultra_fast": {
        "steps": 10,
        "cfg_scale": 6.0,
        "ipadapter_weight": 0.7,
        "description": "超快速生成（10步），适合测试"
      },
      "fast": {
        "steps": 15,
        "cfg_scale": 7.0,
        "ipadapter_weight": 0.8,
        "description": "快速生成（15步），推荐日常使用"
      },
      "balanced": {
        "steps": 20,
        "cfg_scale": 7.5,
        "ipadapter_weight": 0.85,
        "description": "平衡质量和速度（20步）"
      },
      "quality": {
        "steps": 25,
        "cfg_scale": 8.0,
        "ipadapter_weight": 0.9,
        "description": "高质量生成（25步），角色一致性更强"
      }
    },
    "resolutions": {
      "square_768": {
        "width": 768,
        "height": 768,
        "description": "正方形 1:1"
      },
      "landscape_16_9": {
        "width": 1024,
        "height": 576,
        "description": "横屏 16:9"
      },
      "portrait_9_16": {
        "width": 576,
        "height": 1024,
        "description": "竖屏 9:16"
      }
    }
  },
  "negative_prompt": {
    "default": "(worst quality, low quality:1.4), (ugly:1.3), deformed, distorted, disfigured, bad anatomy, bad hands, missing limbs, extra limbs, fused fingers, too many fingers, long neck, mutation, mutated, blurry, jpeg artifacts, text, watermark, signature, cartoon, anime, 3d render, plastic skin, doll-like",
    "additional": [
      "nsfw",
      "nude",
      "gross proportions",
      "malformed limbs"
    ]
  },
  "ipadapter_config": {
    "enabled": true,
    "mode": "faceid_plus_v2",
    "face_detection": true,
    "style_transfer": false,
    "composition_transfer": false,
    "weight_range": {
      "min": 0.5,
      "max": 1.0,
      "default": 0.8
    },
    "lora_strength_range": {
      "min": 0.3,
      "max": 1.0,
      "default": 0.6
    },
    "reference_image_requirements": {
      "min_images": 1,
      "recommended_images": 3,
      "types": ["full_body", "half_body", "close_up"],
      "quality": "high_resolution",
      "angles": ["front", "side", "three_quarter"]
    },
    "notes": [
      "使用 IP-Adapter FaceID Plus V2 模式保证面部和全身一致性",
      "FaceID Plus V2 通过 LoRA 增强面部特征，同时保持整体外观",
      "为每个角色准备多角度参考图：全身照、半身照、特写",
      "更高的 weight 值会增强整体一致性，包括服装和体型特征",
      "weight_faceidv2 控制面部特征强度（默认 1.0）",
      "快速模式（10-15步）适合批量生成和测试",
      "质量模式（20-25步）适合最终成品"
    ]
  }
}
