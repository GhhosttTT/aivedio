{
  "workflow": {
    "name": "AI Short Drama Professional - SDXL + LCM",
    "description": "专业级 AI 短剧工作流 - SDXL + LCM 加速 + IP-Adapter 角色一致性",
    "version": "2.0.0"
  },
  "nodes": {
    "checkpoint_loader": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "sd_xl_base_1.0.safetensors"
      }
    },
    "lcm_lora_loader": {
      "class_type": "LoraLoader",
      "inputs": {
        "model": ["checkpoint_loader", 0],
        "clip": ["checkpoint_loader", 1],
        "lora_name": "lcm-lora-sdxl.safetensors",
        "strength_model": 1.0,
        "strength_clip": 1.0
      }
    },
    "ipadapter_loader": {
      "class_type": "IPAdapterUnifiedLoaderFaceID",
      "inputs": {
        "model": ["lcm_lora_loader", 0],
        "preset": "FACEID PLUS V2",
        "lora_strength": 0.6,
        "provider": "CPU"
      }
    },
    "clip_vision_loader": {
      "class_type": "CLIPVisionLoader",
      "inputs": {
        "clip_name": "CLIP-ViT-bigG-14-laion2B-39B-b160k.safetensors"
      }
    },
    "load_reference_image": {
      "class_type": "LoadImage",
      "inputs": {
        "image": ""
      }
    },
    "apply_ipadapter": {
      "class_type": "IPAdapterFaceID",
      "inputs": {
        "model": ["ipadapter_loader", 0],
        "ipadapter": ["ipadapter_loader", 1],
        "image": ["load_reference_image", 0],
        "weight": 0.85,
        "weight_faceidv2": 1.0,
        "weight_type": "linear",
        "combine_embeds": "concat",
        "start_at": 0.0,
        "end_at": 1.0,
        "embeds_scaling": "V only",
        "insightface": null
      }
    },
    "clip_text_encode_positive": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "(masterpiece, best quality, ultra-detailed:1.3), (photorealistic:1.4), (handsome man:1.3), beautiful face, perfect anatomy, sharp focus, professional photography, cinematic lighting, 8k uhd, highly detailed, film grain",
        "clip": ["lcm_lora_loader", 1]
      }
    },
    "clip_text_encode_negative": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "(worst quality, low quality:1.5), (ugly:1.4), deformed, distorted, disfigured, bad anatomy, bad hands, missing limbs, extra limbs, fused fingers, too many fingers, long neck, mutation, mutated, blurry, jpeg artifacts, text, watermark, signature, cartoon, anime, 3d render, plastic skin, doll-like, nsfw, nude",
        "clip": ["lcm_lora_loader", 1]
      }
    },
    "empty_latent_image": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": 1024,
        "height": 576,
        "batch_size": 1
      }
    },
    "ksampler": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 0,
        "steps": 8,
        "cfg": 2.0,
        "sampler_name": "euler_ancestral",
        "scheduler": "sgm_uniform",
        "denoise": 1.0,
        "model": ["apply_ipadapter", 0],
        "positive": ["clip_text_encode_positive", 0],
        "negative": ["clip_text_encode_negative", 0],
        "latent_image": ["empty_latent_image", 0]
      }
    },
    "vae_decode": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["ksampler", 0],
        "vae": ["checkpoint_loader", 2]
      }
    },
    "save_image": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "short_drama_sdxl",
        "images": ["vae_decode", 0]
      }
    }
  },
  "parameters": {
    "default": {
      "width": 1024,
      "height": 576,
      "steps": 8,
      "cfg_scale": 2.0,
      "sampler": "euler_ancestral",
      "scheduler": "sgm_uniform",
      "seed": -1,
      "ipadapter_weight": 0.85,
      "ipadapter_lora_strength": 0.6
    },
    "presets": {
      "ultra_fast": {
        "steps": 4,
        "cfg_scale": 1.5,
        "ipadapter_weight": 0.75,
        "description": "超快速（4步），LCM 极速模式"
      },
      "fast": {
        "steps": 8,
        "cfg_scale": 2.0,
        "ipadapter_weight": 0.85,
        "description": "快速（8步），推荐日常使用"
      },
      "balanced": {
        "steps": 12,
        "cfg_scale": 2.5,
        "ipadapter_weight": 0.9,
        "description": "平衡（12步），质量更好"
      },
      "quality": {
        "steps": 15,
        "cfg_scale": 3.0,
        "ipadapter_weight": 0.95,
        "description": "高质量（15步），最终成品"
      }
    },
    "resolutions": {
      "landscape_16_9": {
        "width": 1024,
        "height": 576,
        "description": "横屏 16:9（推荐）"
      },
      "portrait_9_16": {
        "width": 576,
        "height": 1024,
        "description": "竖屏 9:16"
      },
      "square": {
        "width": 1024,
        "height": 1024,
        "description": "正方形 1:1"
      }
    }
  },
  "negative_prompt": {
    "default": "(worst quality, low quality:1.5), (ugly:1.4), deformed, distorted, disfigured, bad anatomy, bad hands, missing limbs, extra limbs, fused fingers, too many fingers, long neck, mutation, mutated, blurry, jpeg artifacts, text, watermark, signature, cartoon, anime, 3d render, plastic skin, doll-like, nsfw, nude",
    "additional": [
      "gross proportions",
      "malformed limbs",
      "bad proportions"
    ]
  },
  "ipadapter_config": {
    "enabled": true,
    "mode": "faceid_plus_v2",
    "face_detection": true,
    "style_transfer": false,
    "composition_transfer": false,
    "weight_range": {
      "min": 0.7,
      "max": 1.0,
      "default": 0.85
    },
    "lora_strength_range": {
      "min": 0.3,
      "max": 1.0,
      "default": 0.6
    },
    "reference_image_requirements": {
      "min_images": 1,
      "recommended_images": 3,
      "types": ["full_body", "half_body", "close_up"],
      "quality": "high_resolution",
      "angles": ["front", "side", "three_quarter"]
    },
    "notes": [
      "使用 SDXL + LCM LoRA 实现 4-8 步快速生成",
      "IP-Adapter FaceID Plus V2 保证角色一致性",
      "CFG 降低到 2.0 适配 LCM 特性",
      "使用 sgm_uniform scheduler 提升质量",
      "分辨率建议 1024x576 或更高",
      "为每个角色准备多角度参考图效果最佳"
    ]
  }
}
